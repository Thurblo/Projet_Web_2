{% extends "base.html.twig" %}

{% block title %}Profil pilote{% endblock %}

{% block content %}
<div class="container py-5" style="max-width: 750px;">

    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <div class="d-flex align-items-center gap-4 mb-4 pb-3 border-bottom">
            <div class="bg-warning bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center text-warning fw-bold"
                 style="width:70px;height:70px;font-size:1.8rem;flex-shrink:0;">
                {{ pilote.prenom|first|upper }}
            </div>
            <div class="flex-grow-1">
                <h4 class="fw-bold mb-1">{{ pilote.prenom }} {{ pilote.nom }}</h4>
                <span class="badge text-bg-warning rounded-pill px-3">
                    <i class="bi bi-person-badge-fill me-1"></i>Pilote
                </span>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <p class="text-muted small mb-1">Prénom</p>
                <p class="fw-semibold mb-0">{{ pilote.prenom }}</p>
            </div>
            <div class="col-md-6">
                <p class="text-muted small mb-1">Nom</p>
                <p class="fw-semibold mb-0">{{ pilote.nom }}</p>
            </div>
            <div class="col-md-12">
                <p class="text-muted small mb-1">Email</p>
                <p class="fw-semibold mb-0">{{ pilote.email }}</p>
            </div>
        </div>

        <div class="d-flex gap-3 mt-4">
            <a href="{{ url_for('pilotes.modifier', {'id': pilote.id}) }}"
               class="btn btn-warning rounded-3 fw-semibold">
                <i class="bi bi-pencil-fill me-2"></i>Modifier
            </a>
            <a href="{{ url_for('liste_pilotes') }}"
               class="btn btn-outline-secondary rounded-3 fw-semibold">
                <i class="bi bi-arrow-left me-2"></i>Retour
            </a>
        </div>
    </div>

</div>
{% endblock %}