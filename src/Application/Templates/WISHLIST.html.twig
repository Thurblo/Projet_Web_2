{% extends "base.html.twig" %}

{% block title %}Wishlist{% endblock %}

{% block content %}
<div class="bg-light py-4 container-fluid w-75">
    <div class="text-center mb-5">
        <h1 class="display-3 fw-bold text-primary">Wishlist</h1>
        <p class="lead text-secondary">Votre wishlist personnelle : les offres qui vous font rêver, à portée de clic.</p>
    </div>

    {% if offres|length > 0 %}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for offre in offres %}
                <div class="col">
                    <div class="card shadow card-hover border-0">
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <h5 class="fw-bold mb-1">{{ offre.titre }}</h5>
                                <a href="{{ url_for('wishlist.toggle', { 'id': offre.id }) }}" class="text-decoration-none">
                                    <i class="bi bi-bookmark-fill fs-4 text-primary"></i>
                                </a>
                            </div>
                            <p class="text-secondary mb-2">
                                <i class="bi bi-building me-1"></i>{{ offre.entreprise.nom }}
                            </p>
                            <div class="mt-3">
                                <span class="badge bg-light text-dark me-2 px-3 py-2">{{ offre.duree }} mois</span>
                                <span class="badge bg-light text-dark me-2 px-3 py-2">{{ offre.niveau }}</span>
                                <span class="badge bg-light text-dark px-3 py-2">{{ offre.ville }}</span>
                            </div>
                            <p class="text-secondary mt-3 small">
                                {{ offre.description|slice(0, 100) }}{% if offre.description|length > 100 %}...{% endif %}
                            </p>
                            <div class="d-flex gap-2 mt-3">
                                <a href="{{ url_for('offres.description', { 'id': offre.id }) }}"
                                   class="btn btn-outline-primary flex-fill rounded-4 py-2 text-decoration-none">Voir</a>
                                <a href="/candidatures/postuler/{{ offre.id }}"
                                   class="btn btn-primary flex-fill rounded-4 py-2 text-decoration-none">Postuler</a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-5">
            <i class="bi bi-bookmark fs-1 text-secondary mb-3 d-block"></i>
            <h3 class="text-secondary">Votre wishlist est vide</h3>
            <a href="{{ url_for('home') }}" class="btn btn-primary rounded-5 px-4 mt-3 text-decoration-none">
                <i class="bi bi-search me-2"></i>Voir les offres
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}