{% extends "base.html.twig" %}

{% block title %}Créer une offre{% endblock %}
{% block head %}
    {{ parent() }}
{% endblock %}
{% block content %}
<div class="container my-4">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body d-flex align-items-start justify-content-between">
           <div>
                <h2 class="fw-bold mb-2">Design Studio</h2>
                <p class="text-secondary mb-3"><i class="bi bi-building me-1"></i>Agence de design Créée en 2015</p>
                <div class="d-flex flex-wrap gap-3">
                    <span class="badge bg-light text-secondary my-2"><i class="bi bi-geo-alt me-1"></i>Bordeaux</span>
                    <span class="badge bg-light text-secondary my-2"><i class="bi bi-people me-1"></i>100 salariés</span>
                    <span class="badge bg-light text-secondary my-2"><i class="bi bi-telephone me-1"></i>05 56 12 34 56</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h4><strong>Informations générales</strong></h4>
            
            <div class="row mt-4">
                <div class="col-md-6 mb-3">
                    <p class="text-secondary mb-1"><i class="bi bi-calendar3 me-2"></i>Date de création</p>
                    <strong>15 septembre 2015</strong>
                </div>
                <div class="col-md-6 mb-3">
                    <p class="text-secondary mb-1"><i class="bi bi-tag me-2"></i>Type d'entreprise</p>
                    <strong>Agence de design & innovation</strong>
                </div>
                <div class="col-md-6 mb-3">
                    <p class="text-secondary mb-1"><i class="bi bi-envelope me-2"></i>Email</p>
                    <strong>contact@designstudio.fr</strong>
                </div>
                <div class="col-md-6 mb-3">
                    <p class="text-secondary mb-1"><i class="bi bi-globe me-2"></i>Site web</p>
                    <strong>www.designstudio.fr</strong>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body ">
            <h4><strong>Description</strong></h4>
            <p class="text-secondary mt-3">Agence de design spécialisée dans les interfaces digitales et l'expérience utilisateur. Nous accompagnons les startups et grandes entreprises dans la création de produits innovants depuis 2015. Notre équipe pluridisciplinaire allie créativité et expertise technique pour deliver des solutions intuitives et esthétiques.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body ">
            <h4><strong>Domaines d'expertise</strong></h4>
            <div class="row mt-3">
                <div class="col-md-4">
                    <p><i class="bi bi-check text-primary me-2"></i>UX/UI Design</p>
                </div>
                <div class="col-md-4">
                    <p><i class="bi bi-check text-primary me-2"></i>Design d'interfaces mobiles</p>
                </div>
                <div class="col-md-4">
                    <p><i class="bi bi-check text-primary me-2"></i>Prototypage interactif</p>
                </div>
                <div class="col-md-4">
                    <p><i class="bi bi-check text-primary me-2"></i>Tests utilisateurs</p>
                </div>
                <div class="col-md-4">
                    <p><i class="bi bi-check text-primary me-2"></i>Design system</p>
                </div>
                <div class="col-md-4">
                    <p><i class="bi bi-check text-primary me-2"></i>Consulting produit</p>
                </div>
            </div>
        </div>
    </div>

