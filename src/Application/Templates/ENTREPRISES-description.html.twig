            <h4><strong>Évaluation</strong></h4>
            <div class="d-flex align-items-center mt-3">
                <div class="display-6 fw-bold me-3">4/5</div>
            </div>
            <p class="text-secondary mt-2">Entreprise recommandée par votre pilote</p>
        </div>
    </div>

   
    <h4 class="fw-bold mb-3 mt-5">Offres disponibles chez Design Studio</h4>
