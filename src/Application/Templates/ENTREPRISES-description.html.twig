{% extends "base.html.twig" %}

{% block title %}{{ entreprise.nom }} - Détails{% endblock %}

{% block content %}
<div class="container my-4">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body d-flex align-items-start justify-content-between">
            <div>
                <h2 class="fw-bold mb-2">{{ entreprise.nom }}</h2>
                <p class="text-secondary mb-3"><i class="bi bi-building me-1"></i>{{ entreprise.type }}, Crée en {{ entreprise.dateCreation|date('Y') }}</p>
                <div class="d-flex flex-wrap gap-3">
                    <span class="badge bg-light text-secondary my-2"><i class="bi bi-geo-alt me-1"></i>{{ entreprise.ville }}</span>
                    <span class="badge bg-light text-secondary my-2"><i class="bi bi-people me-1"></i>{{ entreprise.salaries }} salariés</span>
                    <span class="badge bg-light text-secondary my-2"><i class="bi bi-telephone me-1"></i>{{ entreprise.telephone }}</span>
                    <span class="badge {% if entreprise.statut == 'Actif' %}bg-success{% else %}bg-danger{% endif %} text-white my-2">{{ entreprise.statut }}</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h4><strong>Informations générales</strong></h4>
            
            <div class="row mt-4">
                <div class="col-md-6 mb-3">
                    <p class="text-secondary mb-1"><i class="bi bi-calendar3 me-2"></i>Date de création</p>
                    <strong>{{ entreprise.dateCreation }}</strong>
                </div>
                <div class="col-md-6 mb-3">
                    <p class="text-secondary mb-1"><i class="bi bi-tag me-2"></i>Type d'entreprise</p>
                    <strong>{{ entreprise.type }}</strong>
                </div>
                <div class="col-md-6 mb-3">
                    <p class="text-secondary mb-1"><i class="bi bi-envelope me-2"></i>Email</p>
                    <strong>{{ entreprise.email }}</strong>
                </div>
                <div class="col-md-6 mb-3">
                    <p class="text-secondary mb-1"><i class="bi bi-telephone me-2"></i>Téléphone</p>
                    <strong>{{ entreprise.telephone }}</strong>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h4><strong>Description</strong></h4>
            <p class="text-secondary mt-3">{{ entreprise.description }}</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h4><strong>Domaines d'expertise</strong></h4>
            <div class="row mt-3">
                {% set domaines = entreprise.domainesExpertise|split(',') %}
                {% for domaine in domaines %}
                    <div class="col-md-4">
                        <p><i class="bi bi-check text-primary me-2"></i>{{ domaine|trim }}</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-5">
        <div class="card-body p-4">
            <h4><strong>Évaluation</strong></h4>
            <div class="d-flex align-items-center mt-3">
                <strong class="me-3">{{ entreprise.evaluation }}/5</strong>
                <div class="text-warning">
                    {% set rating = entreprise.evaluation|number_format %}
                    {% for i in 1..5 %}
                        {% if i <= rating %}
                            <i class="bi bi-star-fill"></i>
                        {% else %}
                            <i class="bi bi-star"></i>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
     <!-- SECTION OFFRES DE L'ENTREPRISE -->
    {% if entreprise.offres|length > 0 %}
    <div class="mt-5">
        <h3 class="fw-bold mb-4">Offres d'emploi ({{ entreprise.offres|length }})</h3>
        <div class="row row-cols-3 g-4">
            {% for offre in entreprise.offres %}
            <div class="col-md-4">
                <div class="card shadow card-hover border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <h5 class="fw-bold mb-1 me-2">{{ offre.titre }}</h5>
                            <a href="{{ url_for('wishlist.toggle', { 'id': offre.id }) }}" class="text-decoration-none"><i class="bi bi-bookmark{% if offre.id in wishlistIds %}-fill text-primary{% else %} text-secondary{% endif %} fs-4"></i></a>
                        </div>
                        <p class="text-secondary mb-2"><i class="bi bi-building me-1"></i>{{ entreprise.nom }}</p>
                        <div class="mt-3">
                            <span class="badge bg-light text-dark me-2 px-3 py-2">{{ offre.duree }} mois</span>
                            <span class="badge bg-light text-dark me-2 px-3 py-2">{{ offre.niveau }}</span>
                            <span class="badge bg-light text-dark px-3 py-2">{{ offre.ville }}</span>
                        </div>
                        <p class="text-secondary mt-3 small">{{ offre.description}}</p>
                        <div class="d-flex gap-2 mt-3">
                            <a href="{{ url_for('offres.description', { 'id': offre.id }) }}" class="btn btn-outline-primary flex-fill rounded-4 py-2 text-decoration-none">Voir</a>
                            <button class="btn btn-primary flex-fill rounded-4 py-2">Postuler</button>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% else %}
    <div class="alert alert-info text-center">Aucune offre d'emploi disponible pour cette entreprise pour le moment.</div>
    {% endif %}
</div>
{% endblock %}