{% extends "base.html.twig" %}

{% block title %}Créer un compte Pilote {% endblock %}
{% block head %}
    {{ parent() }}
{% endblock %}
{% block content %}
    <div class="container-fluid mt-5 mb-5 d-flex justify-content-center w-75">
        <div class="border border-primary border-5 rounded-5 ms-5 me-5 py-5 px-4 shadow-lg">
            <h1 class="card-title h1 m-3 border-bottom border-primary border-4 d-inline-block ">Creer un compte </h1>
            <div class="row mx-4 my-5">
                <div class="col-md-6">
                    <label class="form-label" for="nom">Nom</label>
                  <input class="form-control border border-secondary border-3 rounded-3"
                          type="text"
                         id="nom"
                         name="nom"
                         placeholder="Entrez le nom du Pilote">  
                </div>
                <div class="col-md-12 mt-4 ">
                    <label class="form-label" for="prenom">Prenom</label>
                    <input class="form-control border border-secondary border-3 rounded-3" type="text" id="prenom" name="prenom" placeholder="entrée un prenom">
                </div>
                <div class="col-md-12 mt-4 ">
                    <label class="form-label" for="email">Email</label>
                    <input class="form-control border border-secondary border-3 rounded-3" type="email" id="email" name="email" placeholder="Entrez l'email">
                </div>
                <div class="col-md-12 mt-5 ">
                    <div class="d-flex flex-column flex-md-row gap-3 justify-content-between">
                        <button class="btn btn-primary btn-lg rounded-5 px-4 flex-fill" type="submit">Creer le profil </button>
                        <button class="btn btn-secondary btn-lg rounded-5 px-4 flex-fill" type="reset">Annuler</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}