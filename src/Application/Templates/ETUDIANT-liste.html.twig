{% extends "base.html.twig" %}

{% block title %}Liste des étudiants{% endblock %}

{% block content %}
<div class="container py-5" style="max-width: 1400px;">

    {# ── EN-TÊTE ── #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">
                Liste des étudiants
                {% if nom %}<span class="text-primary">« {{ nom }} »</span>{% endif %}
            </h3>
            <p class="text-muted small mb-0">{{ resultats|length }} étudiant(s) trouvé(s)</p>
        </div>
        <a href="/compte?type=etudiant" class="btn btn-primary rounded-3 fw-semibold">
            <i class="bi bi-person-plus-fill me-2"></i>Ajouter un étudiant
        </a>
    </div>

    {# ── LISTE ── #}
    {% if resultats|length > 0 %}
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase text-muted fw-semibold" style="font-size:.72rem;letter-spacing:.08em;">Étudiant</th>
                    <th class="py-3 text-uppercase text-muted fw-semibold" style="font-size:.72rem;letter-spacing:.08em;">Email</th>
                    <th class="py-3 text-uppercase text-muted fw-semibold" style="font-size:.72rem;letter-spacing:.08em;">Rôle</th>
                    <th class="pe-4 py-3 text-end text-uppercase text-muted fw-semibold" style="font-size:.72rem;letter-spacing:.08em;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for etudiant in resultats %}
                <tr>
                    <td class="ps-4 py-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-primary bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center text-primary fw-bold"
                                 style="width:42px;height:42px;flex-shrink:0;font-size:1rem;">
                                {{ etudiant.prenom|first|upper }}
                            </div>
                            <div>
                                <div class="fw-semibold">{{ etudiant.prenom }} {{ etudiant.nom }}</div>
                            </div>
                        </div>
                    </td>
                    <td class="py-3 text-muted small">{{ etudiant.email }}</td>
                    <td class="py-3">
                        <span class="badge text-bg-primary rounded-pill px-3">
                            <i class="bi bi-mortarboard-fill me-1"></i>Étudiant
                        </span>
                    </td>
                    <td class="pe-4 py-3 text-end">
                        <a href="{{ url_for('etudiant.voir', {'id': etudiant.id}) }}"
                           class="btn btn-outline-secondary btn-sm rounded-3 fw-semibold me-1">
                            <i class="bi bi-eye-fill me-1"></i>Voir
                        </a>
                        <a href="{{ url_for('etudiants.modifier', {'id': etudiant.id}) }}"
                           class="btn btn-outline-primary btn-sm rounded-3 fw-semibold me-1">
                            <i class="bi bi-pencil-fill me-1"></i>Modifier
                        </a>
                        <form method="POST" action="/etudiant/supprimer/{{ etudiant.id }}"
                              class="d-inline"
                              onsubmit="return confirm('Supprimer cet étudiant ?')">
                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-3 fw-semibold">
                                <i class="bi bi-trash-fill me-1"></i>Supprimer
                            </button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% else %}
    <div class="card border-0 shadow-sm rounded-4 p-5 text-center">
        <i class="bi bi-people text-muted" style="font-size:3rem;"></i>
        <h5 class="fw-bold mt-3 mb-1">Aucun étudiant trouvé</h5>
        <p class="text-muted small mb-0">Essayez une autre recherche ou ajoutez un étudiant.</p>
    </div>
    {% endif %}

</div>

{% endblock %}
