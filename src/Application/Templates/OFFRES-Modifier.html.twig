{% extends "base.html.twig" %}
{% block title %}Modifier une offre{% endblock %}
{% block content %}
<div class="container-fluid mt-5 mb-5 d-flex justify-content-center w-75">
    <div class="border border-primary border-5 rounded-5 ms-5 me-5 py-5 px-4 shadow-lg">
        <h1 class="card-title h1 m-3 border-bottom border-primary border-4 d-block text-center">Modifier l'offre</h1>

        {% if errors %}
            <div class="alert alert-danger mx-4">
                {% for e in errors %}<div>{{ e }}</div>{% endfor %}
            </div>
        {% endif %}
        {% if success %}
            <div class="alert alert-success mx-4">Modifications enregistrées !</div>
        {% endif %}

        <form method="POST" action="{{ url_for('offres.modifier', { 'id': offre.id }) }}">
            <div class="row mx-4 my-5">
                <div class="col-md-6">
                    <label class="form-label" for="entreprise_id">Entreprise</label>
                    <select class="form-control border border-secondary border-3 rounded-3" id="entreprise_id" name="entreprise_id" required>
                        <option value="">Sélectionnez une entreprise</option>
                        {% for ent in entreprises %}
                            <option value="{{ ent.id }}" {% if ent.id == offre.entreprise.id %}selected{% endif %}>{{ ent.nom }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="titre">Titre de l'offre</label>
                    <input class="form-control border border-secondary border-3 rounded-3" type="text" id="titre" name="titre" value="{{ offre.titre }}">
                </div>
                <div class="col-md-6 mt-4">
                    <label class="form-label" for="telephone">Numéro de téléphone</label>
                    <input class="form-control border border-secondary border-3 rounded-3" type="text" id="telephone" name="telephone" value="{{ offre.telephone }}">
                </div>
                <div class="col-md-6 mt-4">
                    <label class="form-label" for="date">Date de début</label>
                    <input class="form-control border border-secondary border-3 rounded-3" type="date" id="date" name="date" value="{{ offre.dateDebut|date('Y-m-d') }}">
                </div>
                <div class="col-md-6 mt-4">
                    <label class="form-label" for="duree">Durée (mois)</label>
                    <input class="form-control border border-secondary border-3 rounded-3" type="text" id="duree" name="duree" value="{{ offre.duree }}">
                </div>
                <div class="col-md-6 mt-4">
                    <label class="form-label" for="ville">Ville</label>
                    <input class="form-control border border-secondary border-3 rounded-3" type="text" id="ville" name="ville" value="{{ offre.ville }}">
                </div>
                <div class="col-md-6 mt-4">
                    <label class="form-label" for="remuneration">Rémunération (€/mois)</label>
                    <input class="form-control border border-secondary border-3 rounded-3" type="text" id="remuneration" name="remuneration" value="{{ offre.remuneration }}">
                </div>
                <div class="col-md-6 mt-4">
                    <label class="form-label" for="niveau">Niveau requis</label>
                    <input class="form-control border border-secondary border-3 rounded-3" type="text" id="niveau" name="niveau" value="{{ offre.niveau }}">
                </div>
                <div class="col-md-12 mt-4">
                    <label class="form-label" for="description">Description de l'offre</label>
                    <textarea class="form-control border border-secondary border-3 rounded-3" id="description" name="description" rows="5">{{ offre.description }}</textarea>
                </div>
                <div class="col-md-12 mt-4">
                    <label class="form-label" for="missions">Missions</label>
                    <input class="form-control border border-secondary border-3 rounded-3" type="text" id="missions" name="missions" value="{{ offre.missions }}">
                </div>
                <div class="col-md-12 mt-4">
                    <label class="form-label" for="competences">Compétences nécessaires</label>
                    <input class="form-control border border-secondary border-3 rounded-3" type="text" id="competences" name="competences" value="{{ offre.competences }}">
                </div>
                <div class="col-md-12 mt-4">
                    <label class="form-label" for="email">Email</label>
                    <input class="form-control border border-secondary border-3 rounded-3" type="email" id="email" name="email" value="{{ offre.email }}">
                </div>
                <div class="col-md-12 mt-5">
                    <div class="d-flex flex-column flex-md-row gap-3 justify-content-between">
                        <button class="btn btn-primary btn-lg rounded-5 px-4 flex-fill" type="submit">Enregistrer les modifications</button>
                        <a href="{{ url_for('offres') }}" class="btn btn-secondary btn-lg rounded-5 px-4 flex-fill text-center text-decoration-none">Annuler</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
{% endblock %}