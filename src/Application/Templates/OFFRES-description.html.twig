{% extends "base.html.twig" %}

{% block title %}{{ offre.titre }} - Détails de l'offre{% endblock %}

{% block content %}
<div class="container my-4">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body d-flex align-items-start justify-content-between">
            <div>
                <h2 class="fw-bold mb-2">{{ offre.titre }}</h2>
                <p class="text-secondary mb-3"><i class="bi bi-building me-1"></i>{{ offre.entreprise.nom }}</p>
                <div class="d-flex flex-wrap gap-3">
                    <span class="badge bg-light text-secondary my-2"><i class="bi bi-geo-alt me-1"></i>{{ offre.ville }}</span>
                    <span class="badge bg-light text-secondary my-2"><i class="bi bi-calendar me-1"></i>Début : {{ offre.dateDebut|date('d/m/Y') }}</span>
                    <span class="badge bg-light text-secondary my-2"><i class="bi bi-clock me-1"></i>{{ offre.duree }} mois</span>
                    <span class="badge bg-light text-secondary my-2"><i class="bi bi-cash me-1"></i>{{ offre.remuneration }} €/mois</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h4><strong>Informations générales</strong></h4>
            
            <div class="row mt-4">
                <div class="col-md-6 mb-3">
                    <p class="text-secondary mb-1"><i class="bi bi-building me-2"></i>Entreprise</p>
                    <strong>{{ offre.entreprise.nom }}</strong>
                </div>
                <div class="col-md-6 mb-3">
                    <p class="text-secondary mb-1"><i class="bi bi-tag me-2"></i>Niveau requis</p>
                    <strong>{{ offre.niveau }}</strong>
                </div>
                <div class="col-md-6 mb-3">
                    <p class="text-secondary mb-1"><i class="bi bi-envelope me-2"></i>Email de contact</p>
                    <strong>{{ offre.email }}</strong>
                </div>
                <div class="col-md-6 mb-3">
                    <p class="text-secondary mb-1"><i class="bi bi-telephone me-2"></i>Téléphone</p>
                    <strong>{{ offre.telephone }}</strong>
                </div>
                <div class="col-md-6 mb-3">
                    <p class="text-secondary mb-1"><i class="bi bi-calendar3 me-2"></i>Date de début</p>
                    <strong>{{ offre.dateDebut|date('d F Y') }}</strong>
                </div>
                <div class="col-md-6 mb-3">
                    <p class="text-secondary mb-1"><i class="bi bi-clock me-2"></i>Durée</p>
                    <strong>{{ offre.duree }} mois</strong>
                </div>
                <div class="col-md-6 mb-3">
                    <p class="text-secondary mb-1"><i class="bi bi-cash-stack me-2"></i>Rémunération</p>
                    <strong>{{ offre.remuneration }} € par mois</strong>
                </div>
                <div class="col-md-6 mb-3">
                    <p class="text-secondary mb-1"><i class="bi bi-geo-alt me-2"></i>Ville</p>
                    <strong>{{ offre.ville }}</strong>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h4><strong>Description du poste</strong></h4>
            <p class="text-secondary mt-3">{{ offre.description|nl2br }}</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h4><strong>Missions principales</strong></h4>
            <p class="text-secondary mt-3">{{ offre.missions|nl2br }}</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h4><strong>Compétences requises</strong></h4>
            <p class="text-secondary mt-3">{{ offre.competences|nl2br }}</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-5">
        <div class="card-body p-4">
            <div class="d-flex gap-3 justify-content-end">
                <a href="{{ url_for('offres.modifier', { 'id': offre.id }) }}" class="btn btn-primary rounded-4 px-4">Modifier l'offre</a>
                <form action="{{ url_for('offres.supprimer', { 'id': offre.id }) }}" method="POST" class="d-inline"
                      onsubmit="return confirm('Supprimer cette offre ?')">
                    <button type="submit" class="btn btn-danger rounded-4 px-4">Supprimer</button>
                </form>
                <a href="{{ url_for('offres') }}" class="btn btn-secondary rounded-4 px-4">Retour à la liste</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}