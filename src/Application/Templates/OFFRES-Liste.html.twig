                    <div class="col-4">
                        <strong>UI/UX Designer</strong><br>
                        <small class="text-secondary">Design Studio</small>
                    </div>
                    <div class="col-4">
                        <span class="badge bg-light text-dark border me-1">Alternance</span>
                        <span class="badge bg-light text-dark border me-1">12 mois</span>
