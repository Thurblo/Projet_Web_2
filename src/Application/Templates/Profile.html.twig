{% extends "base.html.twig" %}

{% block title %}Mon Profil{% endblock %}

{% block content %}
<div class="container py-5" style="max-width: 750px;">

    {# ── EN-TÊTE ── #}
    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <div class="d-flex align-items-center gap-4">
            <div class="bg-primary rounded-3 d-flex align-items-center justify-content-center text-white fw-bold"
                 style="width:80px;height:80px;font-size:2rem;flex-shrink:0;">
                {{ user.prenom|first|upper }}
            </div>
            <div class="flex-grow-1">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <h4 class="fw-bold mb-0">{{ user.prenom }} {{ user.nom }}</h4>
                    {% if user.isAdmin() %}
                        <span class="badge text-bg-danger rounded-pill px-3">
                            <i class="bi bi-shield-fill me-1"></i>Administrateur
                        </span>
                    {% elseif user.isPilote() %}
                        <span class="badge text-bg-warning rounded-pill px-3">
                            <i class="bi bi-person-badge-fill me-1"></i>Pilote
                        </span>
                    {% else %}
                        <span class="badge text-bg-primary rounded-pill px-3">
                            <i class="bi bi-mortarboard-fill me-1"></i>Étudiant
                        </span>
                    {% endif %}
                </div>
                <p class="text-muted small mb-0">{{ user.email }}</p>
            </div>
            <button class="btn btn-outline-primary btn-sm rounded-3 fw-semibold"
                    data-bs-toggle="modal" data-bs-target="#editModal">
                <i class="bi bi-pencil-fill me-1"></i>Modifier
            </button>
        </div>
    </div>

    {# ── STATISTIQUES ADMIN ── #}
    {% if user.isAdmin() and stats is defined %}
    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <p class="text-uppercase text-secondary fw-semibold small mb-4" style="letter-spacing:.1em;">
            Statistiques globales
        </p>
        <div class="row g-3">
            <div class="col-6 col-md-3">
                <div class="card border-0 bg-primary bg-opacity-10 rounded-3 p-3 text-center">
                    <div class="fw-bold fs-3 text-primary">{{ stats.nb_etudiants }}</div>
                    <div class="text-muted small">Étudiants</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 bg-warning bg-opacity-10 rounded-3 p-3 text-center">
                    <div class="fw-bold fs-3 text-warning">{{ stats.nb_pilotes }}</div>
                    <div class="text-muted small">Pilotes</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 bg-success bg-opacity-10 rounded-3 p-3 text-center">
                    <div class="fw-bold fs-3 text-success">{{ stats.nb_offres }}</div>
                    <div class="text-muted small">Offres</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 bg-info bg-opacity-10 rounded-3 p-3 text-center">
                    <div class="fw-bold fs-3 text-info">{{ stats.nb_entreprises }}</div>
                    <div class="text-muted small">Entreprises</div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    {# ── STATISTIQUES PILOTE ── #}
    {% if user.isPilote() and stats is defined %}
    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <p class="text-uppercase text-secondary fw-semibold small mb-4" style="letter-spacing:.1em;">
            Statistiques
        </p>
        <div class="row g-3">
            <div class="col-6">
                <div class="card border-0 bg-primary bg-opacity-10 rounded-3 p-3 text-center">
                    <div class="fw-bold fs-3 text-primary">{{ stats.nb_etudiants }}</div>
                    <div class="text-muted small">Étudiants</div>
                </div>
            </div>
            <div class="col-6">
                <div class="card border-0 bg-success bg-opacity-10 rounded-3 p-3 text-center">
                    <div class="fw-bold fs-3 text-success">{{ stats.nb_offres }}</div>
                    <div class="text-muted small">Offres</div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    {# ── INFORMATIONS PERSONNELLES ── #}
    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <p class="text-uppercase text-secondary fw-semibold small mb-4" style="letter-spacing:.1em;">
            Informations personnelles
        </p>
        <div class="row g-4">
            <div class="col-md-6">
                <p class="text-muted small mb-1">Prénom</p>
                <p class="fw-semibold mb-0">{{ user.prenom }}</p>
            </div>
            <div class="col-md-6">
                <p class="text-muted small mb-1">Nom</p>
                <p class="fw-semibold mb-0">{{ user.nom }}</p>
            </div>
            <div class="col-md-6">
                <p class="text-muted small mb-1">Email</p>
                <p class="fw-semibold mb-0">{{ user.email }}</p>
            </div>
            <div class="col-md-6">
                <p class="text-muted small mb-1">Rôle</p>
                <p class="fw-semibold mb-0">{{ user.getRole().value|capitalize }}</p>
            </div>
        </div>
    </div>

    {# ── ACTIONS SELON RÔLE ── #}
    {% if user.isAdmin() or user.isPilote() %}
    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <p class="text-uppercase text-secondary fw-semibold small mb-4" style="letter-spacing:.1em;">
            Actions disponibles
        </p>
        <div class="row g-3">
            <div class="col-6">
                <a href="{{ url_for('liste_etudiants') }}" class="card border-0 shadow-sm rounded-4 p-4 text-center text-decoration-none h-100">
                    <div class="text-primary mb-2" style="font-size:2rem;">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div class="fw-bold text-primary">Liste des étudiants</div>
                </a>
            </div>
            {% if user.isAdmin() %}
            <div class="col-6">
                <a href="{{ url_for('liste_pilotes') }}" class="card border-0 shadow-sm rounded-4 p-4 text-center text-decoration-none h-100">
                    <div class="text-warning mb-2" style="font-size:2rem;">
                        <i class="bi bi-person-badge-fill"></i>
                    </div>
                    <div class="fw-bold text-warning">Liste des pilotes</div>
                </a>
            </div>
            {% endif %}
        </div>
    </div>
    {% endif %}

</div>

{# ── MODAL MODIFIER PROFIL ── #}
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header px-4 py-3 border-0">
                <h6 class="modal-title fw-bold">Modifier mon profil</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="POST" action="/profile">
                <div class="modal-body px-4 py-3">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Prénom</label>
                        <input type="text" name="prenom" class="form-control rounded-3"
                               value="{{ user.prenom }}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Nom</label>
                        <input type="text" name="nom" class="form-control rounded-3"
                               value="{{ user.nom }}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Email</label>
                        <input type="email" name="email" class="form-control rounded-3"
                               value="{{ user.email }}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">
                            Nouveau mot de passe <span class="text-muted fw-normal">(laisser vide pour ne pas changer)</span>
                        </label>
                        <input type="password" name="password" class="form-control rounded-3"
                               placeholder="••••••••">
                    </div>
                </div>
                <div class="modal-footer px-4 py-3 border-0 gap-2">
                    <button type="button" class="btn btn-light border rounded-pill px-4 btn-sm"
                            data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 btn-sm fw-semibold">
                        Enregistrer
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const ALL = ['HTML','CSS','JavaScript','TypeScript','React','Vue.js','Angular','Bootstrap',
        'Python','Node.js','SQL','Git','Figma','PHP','Java','C#','Ruby','Swift','Kotlin','Docker'];
    const active = new Set();

    function renderSkills() {
        const grid = document.getElementById('skillsGrid');
        grid.innerHTML = '';
        active.forEach(s => {
            const chip = document.createElement('span');
            chip.className = 'badge rounded-pill border border-primary text-primary bg-white px-3 py-2 fw-normal d-inline-flex align-items-center gap-2';
            chip.innerHTML = `${s}<button class="btn-close" style="font-size:.5rem;" onclick="removeSkill('${s}')"></button>`;
            grid.appendChild(chip);
        });
        document.getElementById('noSkills').classList.toggle('d-none', active.size > 0);
        filterSkills();
    }

    function filterSkills() {
        const q = (document.getElementById('skillSearch').value || '').toLowerCase();
        const wrap = document.getElementById('skillOptions');
        wrap.innerHTML = '';
        ALL.filter(s => s.toLowerCase().includes(q)).forEach(s => {
            const btn = document.createElement('button');
            btn.className = 'dropdown-item rounded-2 d-flex justify-content-between align-items-center small py-2';
            btn.innerHTML = `<span>${s}</span>${active.has(s) ? '<i class="bi bi-check2 text-primary"></i>' : ''}`;
            btn.onclick = () => { active.has(s) ? active.delete(s) : active.add(s); renderSkills(); };
            wrap.appendChild(btn);
        });
    }

    function removeSkill(s) { active.delete(s); renderSkills(); }

    renderSkills();
</script>

{% endblock %}