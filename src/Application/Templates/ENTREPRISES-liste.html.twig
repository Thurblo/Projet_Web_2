{% extends "base.html.twig" %}

{% block title %}Liste des entreprises{% endblock %}

{% block content %}
<div class="container-fluid my-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-primary m-0">Entreprises</h2>
        <div class="d-flex gap-2">
            <span class="badge bg-primary rounded-pill px-3 py-2 fs-6">6 Entreprises</span>
            <button class="btn btn-primary rounded-5 px-3 py-1 fw-bold"><i class="bi bi-building-add"></i> Ajouter</button>
        </div>
    </div>

    <form method="get" action="/entreprises" class="row g-3 mt-4">
        <div class="col-md-10">
            <input type="text" class="form-control" placeholder="Tape le nom d'une entreprise" name="search">
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Rechercher</button>
        </div>
    </form>

    <small class="text-secondary">
        Recherchez une entreprise puis consultez les résultats.
    </small>

    <div class="d-flex flex-column gap-3 mt-3">

        <div class="card border border-primary rounded-4">
            <div class="card-body p-2">
                <div class="row align-items-center g-2">
                    <div class="col-4">
                        <strong>InnoTech Solutions</strong><br>
                        <small class="text-secondary">Paris • 50-200 salariés</small>
                    </div>
                    <div class="col-4">
                        <span class="badge bg-light text-dark border me-1">Tech</span>
                        <span class="badge bg-light text-dark border me-1">4 offres</span>
                        <span class="badge bg-light text-dark border">Actif</span>
                    </div>
                    <div class="col-4 text-end">
                        <button class="btn btn-primary btn-sm rounded-4 px-3">Modifier</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border border-primary rounded-4">
            <div class="card-body p-2">
                <div class="row align-items-center g-2">
                    <div class="col-4">
                        <strong>La Compagnie du Code</strong><br>
                        <small class="text-secondary">Lyon • 10-50 salariés</small>
                    </div>
                    <div class="col-4">
                        <span class="badge bg-light text-dark border me-1">ESN</span>
                        <span class="badge bg-light text-dark border me-1">7 offres</span>
                        <span class="badge bg-light text-dark border">Actif</span>
                    </div>
                    <div class="col-4 text-end">
                        <button class="btn btn-primary btn-sm rounded-4 px-3">Modifier</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border border-primary rounded-4">
            <div class="card-body p-2">
                <div class="row align-items-center g-2">
                    <div class="col-4">
                        <strong>Agence Créative</strong><br>
                        <small class="text-secondary">Bordeaux • 5-25 salariés</small>
                    </div>
                    <div class="col-4">
                        <span class="badge bg-light text-dark border me-1">Marketing</span>
                        <span class="badge bg-light text-dark border me-1">2 offres</span>
                        <span class="badge bg-light text-dark border">Actif</span>
                    </div>
                    <div class="col-4 text-end">
                        <button class="btn btn-primary btn-sm rounded-4 px-3">Modifier</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border border-primary rounded-4">
            <div class="card-body p-2">
                <div class="row align-items-center g-2">
                    <div class="col-4">
                        <strong>Design Studio</strong><br>
                        <small class="text-secondary">Nantes • 5-15 salariés</small>
                    </div>
                    <div class="col-4">
                        <span class="badge bg-light text-dark border me-1">Design</span>
                        <span class="badge bg-light text-dark border me-1">3 offres</span>
                        <span class="badge bg-light text-dark border">Actif</span>
                    </div>
                    <div class="col-4 text-end">
                        <button class="btn btn-primary btn-sm rounded-4 px-3">Modifier</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border border-primary rounded-4">
            <div class="card-body p-2">
                <div class="row align-items-center g-2">
                    <div class="col-4">
                        <strong>DataCorp</strong><br>
                        <small class="text-secondary">Toulouse • 100-500 salariés</small>
                    </div>
                    <div class="col-4">
                        <span class="badge bg-light text-dark border me-1">Data</span>
                        <span class="badge bg-light text-dark border me-1">6 offres</span>
                        <span class="badge bg-light text-dark border">Actif</span>
                    </div>
                    <div class="col-4 text-end">
                        <button class="btn btn-primary btn-sm rounded-4 px-3">Modifier</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border border-primary rounded-4">
            <div class="card-body p-2">
                <div class="row align-items-center g-2">
                    <div class="col-4">
                        <strong>SocialMedia Agency</strong><br>
                        <small class="text-secondary">Lille • 10-30 salariés</small>
                    </div>
                    <div class="col-4">
                        <span class="badge bg-light text-dark border me-1">Communication</span>
                        <span class="badge bg-light text-dark border me-1">5 offres</span>
                        <span class="badge bg-light text-dark border">Actif</span>
                    </div>
                    <div class="col-4 text-end">
                        <button class="btn btn-primary btn-sm rounded-4 px-3">Modifier</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}