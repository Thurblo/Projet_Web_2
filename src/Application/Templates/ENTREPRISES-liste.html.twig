{% extends "base.html.twig" %}

{% block title %}Liste des entreprises{% endblock %}

{% block content %}
<div class="container-fluid my-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary m-0">Entreprises</h2>
        <div class="d-flex gap-2">
            <span class="badge bg-primary rounded-pill px-3 py-2 fs-6">{{ totalEntreprises }} Entreprises</span>
            <a href="{{ url_for('entreprises.creer') }}" class="btn btn-primary rounded-5 px-3 py-1 fw-bold"><i class="bi bi-building-add"></i> Ajouter</a>
        </div>
    </div>

    <form method="get" action="{{ url_for('entreprises') }}" class="row g-3">
        <div class="col-md-10">
            <input type="text" class="form-control" placeholder="Tape le nom d'une entreprise" name="search" value="{{ search }}">
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Rechercher</button>
        </div>
    </form>

    <small class="text-secondary">
        Recherchez une entreprise puis consultez les résultats.
    </small>

    <div class="d-flex flex-column gap-3 mt-3">
        {% for entreprise in entreprises %}
        <div class="card border border-primary rounded-4">
            <div class="card-body p-2">
                <div class="row align-items-center g-2">
                    <div class="col-4">
                        <strong>{{ entreprise.nom }}</strong><br>
                        <small class="text-secondary">{{ entreprise.ville }} • {{ entreprise.salaries }} salariés</small>
                    </div>
                    <div class="col-4">
                        <span class="badge bg-light text-dark border me-1">{{ entreprise.type }}</span>
                        <span class="badge bg-light text-dark border">Actif</span>
                    </div>
                    <div class="col-4 text-end">
                        <a href="{{ url_for('entreprises.modifier', { 'id': entreprise.id }) }}" class="btn btn-primary btn-sm rounded-4 px-3">Modifier</a>
                        <form action="{{ url_for('entreprises.supprimer', { 'id': entreprise.id }) }}" method="POST" class="d-inline" onsubmit="return confirm('Supprimer cette entreprise ?')">
                            <button type="submit" class="btn btn-danger btn-sm rounded-4 px-3">Supprimer</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        {% else %}
        <div class="alert alert-info text-center">
            Aucune entreprise trouvée.
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}