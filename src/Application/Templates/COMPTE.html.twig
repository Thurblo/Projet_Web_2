{% extends "base.html.twig" %}

{% block title %}Créer un compte{% endblock %}

{% block content %}
<div class="container mt-5 mb-5"> 
    <div class="row justify-content-center"> 
    <div class="col-lg-8 col-md-10"> 
    <div class="border border-primary border-5 rounded-5 py-5 px-4 shadow-lg bg-white">
        <h1 class="card-title h1 m-3 border-bottom border-primary border-4 d-inline-block w-75">
            Créer un compte
        </h1>

        <form action="{{ url_for('compte.creer') }}" method="post">
            <div class="row mx-4 my-5">

                <div class="col-md-12">
                    <label class="form-label" for="type">Type de compte</label>
                    <div class="d-flex gap-2">
                        <select class="form-select border border-secondary border-3 rounded-3" id="type" name="type">
                            <option value="">Choisir un type</option>
                            <option value="etudiant" {% if typeCompte == 'etudiant' %}selected{% endif %}>Étudiant</option>
                            {% if isAdmin %}
                                <option value="pilote" {% if typeCompte == 'pilote' %}selected{% endif %}>Pilote</option>
                            {% endif %}
                        </select>
                        <button type="submit" name="action" value="select_type" class="btn btn-outline-primary">OK</button>
                    </div>
                </div>

                <div class="col-md-6 mt-4">
                    <label class="form-label" for="nom">Nom</label>
                    <input class="form-control border border-secondary border-3 rounded-3"
                           type="text" id="nom" name="nom" placeholder="Entrez le nom">
                </div>

                <div class="col-md-6 mt-4">
                    <label class="form-label" for="phone">Numéro de téléphone</label>
                    <input class="form-control border border-secondary border-3 rounded-3" type="tel" id="phone" name="phone" placeholder="Entrez le numéro de téléphone">
                </div>

                <div class="col-md-12 mt-4">
                    <label class="form-label" for="description">Présentation</label>
                    <textarea class="form-control border border-secondary border-3 rounded-3" id="description" name="description" placeholder="Entrez une présentation" rows="5"></textarea>
                </div>

                <div class="col-md-12 mt-4">
                    <label class="form-label" for="email">Email</label>
                    <input class="form-control border border-secondary border-3 rounded-3" type="email" id="email" name="email" placeholder="Entrez l'email">
                </div>

                <div class="col-md-12 mt-4">
                    <label class="form-label" for="password">Mot de passe</label>
                    <input class="form-control border border-secondary border-3 rounded-3" type="password" id="password" name="password" placeholder="Entrez le mot de passe">
                </div>

                {% if typeCompte is defined and typeCompte == 'etudiant' %}
                    <div class="col-md-12 mt-4">
                        <label class="form-label" for="formation">Formation</label>
                        <input class="form-control border border-secondary border-3 rounded-3" type="text" id="formation" name="formation" placeholder="Ex : CESI école d'ingénieur">
                    </div>

                    <div class="col-md-12 mt-4">
                        <label class="form-label" for="campus">Campus</label>
                        <input class="form-control border border-secondary border-3 rounded-3" type="text" id="campus" name="campus" placeholder="Ex : CESI Reims">
                    </div>

                {% elseif typeCompte is defined and typeCompte == 'pilote' %}
                    <div class="col-md-12 mt-4">
                        <label class="form-label" for="entreprise">Entreprise</label>
                        <input class="form-control border border-secondary border-3 rounded-3" type="text" id="entreprise" name="entreprise" placeholder="Nom de l'entreprise">
                    </div>

                    <div class="col-md-12 mt-4">
                        <label class="form-label" for="poste">Poste</label>
                        <input class="form-control border border-secondary border-3 rounded-3" type="text" id="poste" name="poste" placeholder="Ex : Responsable RH">
                    </div>
                {% endif %}

                <div class="col-md-12 mt-5">
                    <div class="d-flex flex-column flex-md-row gap-3 justify-content-between">
                        <button class="btn btn-primary btn-lg rounded-5 px-4 flex-fill" type="submit">
                            Créer le profil
                        </button>
                        <button class="btn btn-outline-secondary btn-lg rounded-5 px-4 flex-fill" type="reset">
                            Annuler
                        </button>
                    </div>
                </div>

            </div>
        </form>
        {% if error is defined %}
            <div class="alert alert-danger rounded-3 mx-4 mt-3">
                <i class="bi bi-exclamation-circle me-2"></i>{{ error }}
            </div>
        {% endif %}
     </div>
  </div>
 </div>
</div>
{% endblock %}