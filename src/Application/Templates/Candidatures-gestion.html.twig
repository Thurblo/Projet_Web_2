{% extends "base.html.twig" %}

{% block title %}Gestion des candidatures{% endblock %}

{% block content %}
<div class="container py-5" style="max-width: 1400px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">Gestion des candidatures</h3>
            <p class="text-muted small mb-0">{{ candidatures|length }} candidature(s) au total</p>
        </div>
    </div>

    {% if candidatures|length > 0 %}
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase text-muted fw-semibold" style="font-size:.72rem;letter-spacing:.08em;">Étudiant</th>
                    <th class="py-3 text-uppercase text-muted fw-semibold" style="font-size:.72rem;letter-spacing:.08em;">Offre</th>
                    <th class="py-3 text-uppercase text-muted fw-semibold" style="font-size:.72rem;letter-spacing:.08em;">Entreprise</th>
                    <th class="py-3 text-uppercase text-muted fw-semibold" style="font-size:.72rem;letter-spacing:.08em;">Date</th>
                    <th class="py-3 text-uppercase text-muted fw-semibold" style="font-size:.72rem;letter-spacing:.08em;">Statut</th>
                    <th class="pe-4 py-3 text-end text-uppercase text-muted fw-semibold" style="font-size:.72rem;letter-spacing:.08em;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for candidature in candidatures %}
                <tr>
                    <td class="ps-4 py-3">
                        <div class="d-flex align-items-center gap-2">
                            <div class="bg-primary bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center text-primary fw-bold"
                                 style="width:36px;height:36px;flex-shrink:0;">
                                {{ candidature.etudiant.prenom|first|upper }}
                            </div>
                            <div>
                                <div class="fw-semibold small">{{ candidature.etudiant.prenom }} {{ candidature.etudiant.nom }}</div>
                                <div class="text-muted" style="font-size:.75rem;">{{ candidature.etudiant.email }}</div>
                            </div>
                        </div>
                    </td>
                    <td class="py-3 fw-semibold small">{{ candidature.offre.titre }}</td>
                    <td class="py-3 text-muted small">{{ candidature.offre.entreprise.nom }}</td>
                    <td class="py-3 text-muted small">{{ candidature.datePostulation|date('d/m/Y') }}</td>
                    <td class="py-3">
                        {% if candidature.statut == 'acceptee' %}
                            <span class="badge text-bg-success rounded-pill px-3">
                                <i class="bi bi-check-circle-fill me-1"></i>Acceptée
                            </span>
                        {% elseif candidature.statut == 'refusee' %}
                            <span class="badge text-bg-danger rounded-pill px-3">
                                <i class="bi bi-x-circle-fill me-1"></i>Refusée
                            </span>
                        {% else %}
                            <span class="badge text-bg-warning rounded-pill px-3">
                                <i class="bi bi-clock-fill me-1"></i>En attente
                            </span>
                        {% endif %}
                    </td>
                    <td class="pe-4 py-3 text-end">
                        <form method="POST" action="/candidatures/statut/{{ candidature.id }}" class="d-flex gap-1 justify-content-end">
                            <select name="statut" class="form-select form-select-sm rounded-3" style="width:140px;">
                                <option value="en_attente" {% if candidature.statut == 'en_attente' %}selected{% endif %}>En attente</option>
                                <option value="acceptee" {% if candidature.statut == 'acceptee' %}selected{% endif %}>Acceptée</option>
                                <option value="refusee" {% if candidature.statut == 'refusee' %}selected{% endif %}>Refusée</option>
                            </select>
                            <button type="submit" class="btn btn-primary btn-sm rounded-3 fw-semibold">
                                <i class="bi bi-check-lg"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% else %}
    <div class="card border-0 shadow-sm rounded-4 p-5 text-center">
        <i class="bi bi-inbox text-muted" style="font-size:3rem;"></i>
        <h5 class="fw-bold mt-3 mb-1">Aucune candidature</h5>
        <p class="text-muted small mb-0">Aucun étudiant n'a encore postulé.</p>
    </div>
    {% endif %}

</div>
{% endblock %}