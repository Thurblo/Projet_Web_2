{% extends "base.html.twig" %}

{% block title %}Index{% endblock %}
{% block head %}
    {{ parent() }}

{% endblock %}
{% block content %}
<!-- CONTENU PRINCIPAL -->
  <div class="container mt-4" style="max-width: 960px;">

    <!-- SECTION : Offres recommandées -->
    <div class="border border-dark rounded-4 p-4 mb-4">
      <h6 class="fw-semibold mb-3">Offres pouvant vous intéresser</h6>
      <div class="row g-3">

        <!-- Carte offre 1 -->
        <div class="col-12 col-md-4">
          <div class="border border-dark rounded-3 p-3 h-100" role="button" onclick="afficherDetail(1)" style="cursor:pointer;">
            <span class="badge bg-dark mb-2">Stage</span>
            <p class="fw-semibold mb-1 small">Développeur Web Full Stack</p>
            <p class="text-muted small mb-1">Paris · TechCorp</p>
            <p class="small mb-0">800 €/mois</p>
          </div>
        </div>

        <!-- Carte offre 2 -->
        <div class="col-12 col-md-4">
          <div class="border border-dark rounded-3 p-3 h-100" role="button" onclick="afficherDetail(2)" style="cursor:pointer;">
            <span class="badge bg-dark mb-2">Stage</span>
            <p class="fw-semibold mb-1 small">Intégrateur HTML/CSS</p>
            <p class="text-muted small mb-1">Lyon · AgenceWeb</p>
            <p class="small mb-0">Gratification légale</p>
          </div>
        </div>

        <!-- Carte offre 3 -->
        <div class="col-12 col-md-4">
          <div class="border border-dark rounded-3 p-3 h-100" role="button" onclick="afficherDetail(3)" style="cursor:pointer;">
            <span class="badge bg-dark mb-2">Stage</span>
            <p class="fw-semibold mb-1 small">Développeur PHP/Symfony</p>
            <p class="text-muted small mb-1">Bordeaux · StartupIO</p>
            <p class="small mb-0">1 200 €/mois</p>
          </div>
        </div>

      </div>
    </div>

    <!-- SECTION : Détail de l'offre (s'affiche au clic) -->
    <div class="border border-dark rounded-4 p-4 mb-5" id="detail-offre">
      <div id="detail-placeholder" class="text-muted small text-center py-4">
        ← Cliquez sur une offre pour voir le détail
      </div>

      <!-- Contenu détail -->
      <div id="detail-contenu" class="d-none">
        <div class="d-flex justify-content-between align-items-start mb-3">
          <div>
            <h5 class="fw-bold mb-1" id="detail-titre"></h5>
            <p class="text-muted small mb-0" id="detail-entreprise"></p>
          </div>
          <span class="badge bg-dark" id="detail-type"></span>
        </div>

        <hr class="border-dark"/>

        <div class="row g-3 mb-3">
          <div class="col-6 col-md-3">
            <p class="small text-muted mb-0">Localisation</p>
            <p class="small fw-semibold mb-0" id="detail-lieu"></p>
          </div>
          <div class="col-6 col-md-3">
            <p class="small text-muted mb-0">Rémunération</p>
            <p class="small fw-semibold mb-0" id="detail-salaire"></p>
          </div>
          <div class="col-6 col-md-3">
            <p class="small text-muted mb-0">Début</p>
            <p class="small fw-semibold mb-0" id="detail-debut"></p>
          </div>
          <div class="col-6 col-md-3">
            <p class="small text-muted mb-0">Expérience</p>
            <p class="small fw-semibold mb-0" id="detail-experience"></p>
          </div>
        </div>

        <p class="small fw-semibold mb-1">Description du poste</p>
        <p class="small mb-3" id="detail-description"></p>

        <p class="small fw-semibold mb-1">Compétences requises</p>
        <div id="detail-competences" class="d-flex flex-wrap gap-2 mb-4"></div>

        <div class="d-flex gap-2">
          <button class="btn btn-dark btn-sm">Postuler</button>
          <button class="btn btn-outline-dark btn-sm">Ajouter à la Wishlist ♡</button>
        </div>
      </div>
    </div>

  </div>

  <script>
    const offres = {
      1: {
        titre: "Développeur Web Full Stack",
        entreprise: "TechCorp",
        type: "Stage",
        lieu: "Paris (75)",
        salaire: "800 €/mois",
        debut: "Dès que possible",
        experience: "2 ans min.",
        description: "Vous rejoindrez une équipe dynamique pour développer et maintenir des applications web modernes. Vous interviendrez sur l'ensemble de la stack technique, du backend API au frontend responsive.",
        competences: ["PHP", "Symfony", "JavaScript", "React", "SQL", "Git"]
      },
      2: {
        titre: "Intégrateur HTML/CSS",
        entreprise: "AgenceWeb",
        type: "Stage",
        lieu: "Lyon (69)",
        salaire: "Gratification légale",
        debut: "Janvier 2025",
        experience: "Débutant accepté",
        description: "Au sein de notre agence créative, vous intégrerez des maquettes Figma en pages web responsive. Vous travaillerez en binôme avec un développeur senior.",
        competences: ["HTML", "CSS", "Bootstrap", "Figma", "Git"]
      },
      3: {
        titre: "Développeur PHP/Symfony",
        entreprise: "StartupIO",
        type: "Stage",
        lieu: "Bordeaux (33)",
        salaire: "1 200 €/mois",
        debut: "Septembre 2025",
        experience: "En formation Bac+3/5",
        description: "Intégrez notre startup en pleine croissance et participez au développement de notre plateforme SaaS. Environnement agile, beaucoup d'autonomie et de montée en compétences.",
        competences: ["PHP", "Symfony", "Twig", "MySQL", "Docker", "API REST"]
      }
    };
    
    function afficherDetail(id) {
      const o = offres[id];
      document.getElementById('detail-placeholder').classList.add('d-none');
      document.getElementById('detail-contenu').classList.remove('d-none');

      document.getElementById('detail-titre').textContent = o.titre;
      document.getElementById('detail-entreprise').textContent = o.entreprise;
      document.getElementById('detail-type').textContent = o.type;
      document.getElementById('detail-lieu').textContent = o.lieu;
      document.getElementById('detail-salaire').textContent = o.salaire;
      document.getElementById('detail-debut').textContent = o.debut;
      document.getElementById('detail-experience').textContent = o.experience;
      document.getElementById('detail-description').textContent = o.description;

      const comp = document.getElementById('detail-competences');
      comp.innerHTML = '';
      o.competences.forEach(c => {
        const badge = document.createElement('span');
        badge.className = 'badge border border-dark text-dark bg-white small';
        badge.textContent = c;
        comp.appendChild(badge);
      });

      document.getElementById('detail-offre').scrollIntoView({ behavior: 'smooth' });
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
{% endblock %}