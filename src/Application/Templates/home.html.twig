{% extends "base.html.twig" %}

{% block title %}Accueil{% endblock %}

{% block head %}
    {{ parent() }}
{% endblock %}

{% block content %}

{# ── BANNIÈRE HERO ── #}
<div class="bg-primary text-white py-5 mb-4">
    <div class="container-xl text-center">
        <h1 class="fw-bold display-5 mb-2">Trouve ton stage idéal</h1>
        <p class="lead mb-4 opacity-75">Des centaines d'offres de stage vous attendent. Commencez votre recherche dès maintenant.</p>
        <div class="d-flex justify-content-center gap-3">
            <a href="{{ url_for('offres') }}" class="btn btn-light btn-lg rounded-pill fw-bold px-4 w-25">
                <i class="bi bi-search me-2"></i>Voir toutes les offres
            </a>
            <a href="{{ url_for('entreprises') }}" class="btn btn-outline-light btn-lg rounded-pill px-4 w-25">
                <i class="bi bi-building me-2"></i>Les entreprises
            </a>
        </div>
    </div>
</div>

<div class="container-xl py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="fw-bold mb-0">Dernières offres ajoutées</h5>
            <p class="text-muted small mb-0">Consultez les offres les plus récentes</p>
        </div>
        <a href="{{ url_for('offres') }}" class="btn btn-outline-primary rounded-3 fw-semibold btn-sm">
            Voir toutes <i class="bi bi-arrow-right ms-1"></i>
        </a>
    </div>

    {# ── CAROUSEL ── #}
    {% if offres|length > 0 %}
    <div id="offresCarousel" class="carousel slide mb-5" data-bs-ride="carousel" data-bs-interval="4000">

        {# Indicateurs #}
        <div class="carousel-indicators">
            {% for offre in offres %}
                <button type="button" data-bs-target="#offresCarousel" data-bs-slide-to="{{ loop.index0 }}"
                        class="{% if loop.first %}active{% endif %} bg-primary"
                        style="width:8px;height:8px;border-radius:50%;border:none;opacity:.4;">
                </button>
            {% endfor %}
        </div>

        <div class="carousel-inner">
            {% for offre in offres %}
            <div class="carousel-item {% if loop.first %}active{% endif %}">
                <div class="card border-0 shadow-sm rounded-4 p-0 overflow-hidden mx-auto" style="max-width:700px;">

                    {# Header coloré #}
                    <div class="bg-primary bg-opacity-10 px-4 pt-4 pb-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <a href="{{ url_for('offres.description', { 'id': offre.id }) }}" class="text-decoration-none">
                                    <h5 class="fw-bold mb-1 text-dark">{{ offre.titre }}</h5>
                                </a>
                                <p class="text-primary fw-semibold small mb-0">{{ offre.entreprise }}</p>
                            </div>
                            <span class="badge text-bg-primary rounded-pill px-3 py-2 fw-semibold">
                                {{ offre.remuneration }} €/mois
                            </span>
                        </div>
                    </div>

                    {# Body #}
                    <div class="px-4 py-3">
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <span class="badge bg-light text-dark border rounded-pill px-3">
                                <i class="bi bi-geo-alt me-1"></i>{{ offre.ville }}
                            </span>
                            <span class="badge bg-light text-dark border rounded-pill px-3">
                                <i class="bi bi-clock me-1"></i>{{ offre.duree }} mois
                            </span>
                            <span class="badge bg-light text-dark border rounded-pill px-3">
                                <i class="bi bi-mortarboard me-1"></i>{{ offre.niveau }}
                            </span>
                        </div>

                        <p class="text-muted small mb-3" style="line-height:1.6;">
                            {{ offre.description|slice(0, 150) }}{% if offre.description|length > 150 %}...{% endif %}
                        </p>

                        <div class="d-flex gap-2">
                            {% if user and user.isEtudiant() %}
                                {# Étudiant : Postuler + Wishlist #}
                                <a href="{{ url_for('offres.description', { 'id': offre.id }) }}"
                                   class="btn btn-primary rounded-3 fw-semibold flex-fill">
                                    <i class="bi bi-send-fill me-2"></i>Postuler
                                </a>
                                <a href="{{ url_for('wishlist.toggle', { 'id': offre.id }) }}"
                                   class="btn btn-outline-secondary rounded-3 px-3">
                                    <i class="bi bi-bookmark{% if offre.id in wishlistIds %}-fill text-primary{% endif %}"></i>
                                </a>
                            {% elseif user and user.isAtLeastPilote() %}
                                {# Pilote/Admin : Voir + Gérer #}
                                <a href="{{ url_for('offres.description', { 'id': offre.id }) }}"
                                   class="btn btn-outline-primary rounded-3 fw-semibold flex-fill">
                                    <i class="bi bi-eye-fill me-2"></i>Voir
                                </a>
                                <a href="{{ url_for('offres.modifier', { 'id': offre.id }) }}"
                                   class="btn btn-primary rounded-3 fw-semibold flex-fill">
                                    <i class="bi bi-pencil-fill me-2"></i>Gérer
                                </a>
                            {% else %}
                                {# Non connecté : Voir l'offre #}
                                <a href="{{ url_for('offres.description', { 'id': offre.id }) }}"
                                   class="btn btn-primary rounded-3 fw-semibold flex-fill">
                                    <i class="bi bi-eye-fill me-2"></i>Voir l'offre
                                </a>
                            {% endif %}
                        </div>
                    </div>

                </div>
            </div>
            {% endfor %}
        </div>

        {# Contrôles #}
        <button class="carousel-control-prev" type="button" data-bs-target="#offresCarousel" data-bs-slide="prev"
                style="width:40px;left:-50px;">
            <span class="bg-white border shadow-sm rounded-circle d-flex align-items-center justify-content-center"
                  style="width:36px;height:36px;">
                <i class="bi bi-chevron-left text-dark"></i>
            </span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#offresCarousel" data-bs-slide="next"
                style="width:40px;right:-50px;">
            <span class="bg-white border shadow-sm rounded-circle d-flex align-items-center justify-content-center"
                  style="width:36px;height:36px;">
                <i class="bi bi-chevron-right text-dark"></i>
            </span>
        </button>

    </div>
    {% else %}
    <div class="card border-0 shadow-sm rounded-4 p-5 text-center mb-5">
        <i class="bi bi-briefcase text-muted" style="font-size:3rem;"></i>
        <h5 class="fw-bold mt-3 mb-1">Aucune offre disponible</h5>
        <p class="text-muted small mb-0">Revenez plus tard.</p>
    </div>
    {% endif %}

    {# ── STATISTIQUES ── #}
    {% if stats is defined %}
    <div class="row g-3 mt-2">
        <div class="col-12">
            <h5 class="fw-bold mb-3">StageFinder en chiffres</h5>
        </div>
        <div class="col-6">
            <div class="card border-0 shadow-sm rounded-4 p-4 text-center">
                <div class="fw-bold fs-2 text-primary">{{ stats.nb_offres }}</div>
                <div class="text-muted small mt-1"><i class="bi bi-briefcase-fill me-1"></i>Offres disponibles</div>
            </div>
        </div>
        <div class="col-6">
            <div class="card border-0 shadow-sm rounded-4 p-4 text-center">
                <div class="fw-bold fs-2 text-success">{{ stats.nb_entreprises }}</div>
                <div class="text-muted small mt-1"><i class="bi bi-building-fill me-1"></i>Entreprises partenaires</div>
            </div>
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}