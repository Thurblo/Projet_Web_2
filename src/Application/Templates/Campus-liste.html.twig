{% extends "base.html.twig" %}
{% block title %}Liste des campus{% endblock %}
{% block content %}
<div class="container py-5" style="max-width: 1400px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">Liste des campus</h3>
            <p class="text-muted small mb-0">{{ campus|length }} campus</p>
        </div>
        <a href="/campus/creer" class="btn btn-primary rounded-3 fw-semibold">
            <i class="bi bi-plus-circle-fill me-2"></i>Ajouter un campus
        </a>
    </div>

    {% if campus|length > 0 %}
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase text-muted fw-semibold" style="font-size:.72rem;letter-spacing:.08em;">Campus</th>
                    <th class="py-3 text-uppercase text-muted fw-semibold" style="font-size:.72rem;letter-spacing:.08em;">Ville</th>
                    <th class="py-3 text-uppercase text-muted fw-semibold" style="font-size:.72rem;letter-spacing:.08em;">Étudiants</th>
                    <th class="pe-4 py-3 text-end text-uppercase text-muted fw-semibold" style="font-size:.72rem;letter-spacing:.08em;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for c in campus %}
                <tr>
                    <td class="ps-4 py-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-primary bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center text-primary"
                                 style="width:42px;height:42px;flex-shrink:0;">
                                <i class="bi bi-building-fill"></i>
                            </div>
                            <div class="fw-semibold">{{ c.nom ?? c.ville }}</div>
                        </div>
                    </td>
                    <td class="py-3 text-muted small">{{ c.ville }}</td>
                    <td class="py-3">
                        <span class="badge text-bg-primary rounded-pill px-3">
                            {{ c.etudiants|length }} étudiant(s)
                        </span>
                    </td>
                    <td class="pe-4 py-3 text-end">
                        <a href="/campus/voir/{{ c.id }}" class="btn btn-outline-secondary btn-sm rounded-3 fw-semibold me-1">
                            <i class="bi bi-eye-fill me-1"></i>Voir
                        </a>
                        <a href="/campus/rattacher/{{ c.id }}" class="btn btn-outline-primary btn-sm rounded-3 fw-semibold me-1">
                            <i class="bi bi-person-plus-fill me-1"></i>Rattacher
                        </a>
                        <a href="/campus/modifier/{{ c.id }}" class="btn btn-outline-primary btn-sm rounded-3 fw-semibold me-1">
                            <i class="bi bi-pencil-fill me-1"></i>Modifier
                        </a>
                        <form method="POST" action="/campus/supprimer/{{ c.id }}" class="d-inline"
                              onsubmit="return confirm('Supprimer ce campus ?')">
                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-3 fw-semibold">
                                <i class="bi bi-trash-fill me-1"></i>Supprimer
                            </button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="card border-0 shadow-sm rounded-4 p-5 text-center">
        <i class="bi bi-building text-muted" style="font-size:3rem;"></i>
        <h5 class="fw-bold mt-3 mb-1">Aucun campus</h5>
        <p class="text-muted small mb-3">Commencez par créer un campus.</p>
        <a href="/campus/creer" class="btn btn-primary rounded-3 fw-semibold mx-auto" style="width:fit-content;">
            <i class="bi bi-plus-circle-fill me-2"></i>Créer un campus
        </a>
    </div>
    {% endif %}

</div>
{% endblock %}