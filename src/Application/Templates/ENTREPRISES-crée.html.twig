{% extends "base.html.twig" %}

{% block title %}Ajouter une entreprise{% endblock %}

{% block content %}
    <div class="container-fluid mt-5 mb-5 d-flex justify-content-center w-75">
        <div class="border border-primary border-5 rounded-5 ms-5 me-5 py-5 px-4 shadow-lg">
            <h1 class="card-title h1 m-3 border-bottom border-primary border-4 d-inline-block">Ajouter une Entreprise</h1>
            
            {% if error %}
            <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
                Une erreur est survenue. Veuillez vérifier les informations.
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            {% endif %}
            
            <form method="POST" action="{{ url_for('entreprises.creer') }}">
                <div class="row mx-4 my-5">
                    <div class="col-md-6">
                        <label class="form-label" for="nom">Nom de l'entreprise *</label>
                        <input class="form-control border border-secondary border-3 rounded-3" type="text" id="nom" name="nom" placeholder="Entrez le nom de l'entreprise" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="telephone">Numéro de téléphone *</label>
                        <input class="form-control border border-secondary border-3 rounded-3" type="text" id="telephone" name="telephone" placeholder="Entrez le numéro de téléphone" required>
                    </div>
                    <div class="col-md-6 mt-4">
                        <label class="form-label" for="dateCreation">Date de Création *</label>
                        <input class="form-control border border-secondary border-3 rounded-3" type="date" id="dateCreation" name="dateCreation" required>
                    </div>
                    <div class="col-md-6 mt-4">
                        <label class="form-label" for="type">Type d'entreprise *</label>
                        <input class="form-control border border-secondary border-3 rounded-3" type="text" id="type" name="type" placeholder="Entrez le type d'entreprise" required>
                    </div>

                    <div class="col-md-6 mt-4">
                        <label class="form-label" for="ville">Ville *</label>
                        <input class="form-control border border-secondary border-3 rounded-3" type="text" id="ville" name="ville" placeholder="Entrez la ville" required>
                    </div>
                    <div class="col-md-6 mt-4">
                        <label class="form-label" for="salaries">Salariés *</label>
                        <input class="form-control border border-secondary border-3 rounded-3" type="number" id="salaries" name="salaries" placeholder="Entrez le nombre de salariés" required>
                    </div>
                    
                    <div class="col-md-12 mt-4">
                        <label class="form-label" for="description">Description de l'entreprise *</label>
                        <textarea class="form-control border border-secondary border-3 rounded-3" id="description" name="description" placeholder="Entrez la description de l'entreprise" cols="30" rows="5" required></textarea>
                    </div>
                    <div class="col-md-12 mt-4">
                        <label class="form-label" for="missions">Missions *</label>
                        <input class="form-control border border-secondary border-3 rounded-3" type="text" id="missions" name="missions" placeholder="Entrez les missions" required>
                    </div>
                    <div class="col-md-12 mt-4">
                        <label class="form-label" for="domainesExpertise">Domaines d'expertise *</label>
                        <input class="form-control border border-secondary border-3 rounded-3" type="text" id="domainesExpertise" name="domainesExpertise" placeholder="Entrez les domaines d'expertise" required>
                    </div>
                    <div class="col-md-12 mt-4">
                        <label class="form-label" for="evaluation">Evaluation de l'entreprise *</label>
                        <input class="form-control border border-secondary border-3 rounded-3" type="text" id="evaluation" name="evaluation" placeholder="Entrez l'évaluation de l'entreprise" required>
                    </div>
                    <div class="col-md-12 mt-4">
                        <label class="form-label" for="email">Email *</label>
                        <input class="form-control border border-secondary border-3 rounded-3" type="email" id="email" name="email" placeholder="Entrez l'email" required>
                    </div>
                    <div class="col-md-12 mt-5">
                        <div class="d-flex flex-column flex-md-row gap-3 justify-content-between">
                            <button class="btn btn-primary btn-lg rounded-5 px-4 flex-fill" type="submit">Ajouter l'entreprise</button>
                            <a href="{{ url_for('entreprises') }}" class="btn btn-secondary btn-lg rounded-5 px-4 flex-fill text-center text-decoration-none">Annuler</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
{% endblock %}