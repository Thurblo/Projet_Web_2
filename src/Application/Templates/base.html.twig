<!DOCTYPE html>
<html>
<head>
    {% block head %}
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Offres recommandées</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>.card-hover:hover{transform:translateY(-5px);box-shadow:0 10px 20px;transition:.3s}</style>
    {% endblock %}

    <style>
        body { font-family: 'Noto Sans', sans-serif; background: #F8F9FA; }

        .job-card {
            cursor: pointer;
            border-left: 3px solid transparent !important;
            transition: background 0.15s, border-color 0.15s;
        }
        .job-card:hover { background: #f9f8f7; }
        .job-card.active { background: #eef3fc !important; border-left-color: #2d6ef5 !important; }

        .badge-urgent { background: #fff3cd; color: #7a4a00; border: 1px solid #f5c518; }
        .badge-delay  { background: #e8f4ea; color: #1a6630; border: 1px solid #a3d9a5; }
        .badge-salary { background: #e6f7ed; color: #1a6630; border: 1px solid #7ecb97; }

        .tag-pill { font-size: .72rem; padding: 2px 10px; border-radius: 20px; border: 1px solid #d4d2d0; background: #fff; color: #1a1a1a; }

        .detail-panel { position: sticky; top: 16px; max-height: 90vh; overflow-y: auto; }

        .btn-postuler { background: #2d6ef5; font-weight: 700; font-size: .88rem; }
        .btn-postuler:hover { background: #1a5ae0; }

        .skill-chip { font-size: .75rem; padding: 4px 12px; border-radius: 20px; border: 1px solid #2d6ef5; color: #2d6ef5; background: #eef3fc; }
        .meta-chip  { font-size: .78rem; padding: 4px 14px; border-radius: 20px; border: 1px solid #d4d2d0; background: #f3f2f1; }

        .icon-btn { background: none; border: 1px solid #d4d2d0; border-radius: 4px; width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; font-size: .95rem; color: #595959; transition: background .1s; }
        .icon-btn:hover { background: #e4e2e0; }

        .apply-link { color: #2d6ef5; font-size: .75rem; font-weight: 600; text-decoration: none; }

        html, body { height: 100%; }
        body { display: flex; flex-direction: column; min-height: 100vh; }
        main#content { flex: 1; }
    </style>
</head>

<body>

    {# ── NAVBAR ── #}
    <header>
        <nav class="navbar navbar-expand-lg bg-white border-bottom px-4">
            <a class="navbar-brand fw-bold" href="/home">
                <img src="/images/Logo_v2.png" alt="Logo" width="100" height="40" class="d-inline-block align-text-top">
            </a>
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarMain"
                    aria-controls="navbarMain"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto"></ul>

                <ul class="navbar-nav align-items-center">

                    {% if user %}

                        {# ── ETUDIANT ── #}
                        {% if user.isEtudiant() %}
                            <li class="nav-item"><a class="nav-link text-dark" href="/wishlist">Wishlist</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" href="/offres">Offres</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" href="/entreprises">Entreprises</a></li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/candidatures">
                                    <i class="bi bi-file-earmark-text me-1"></i>Mes candidatures
                                </a>
                            </li>
                        {% endif %}

                        {# ── PILOTE ── #}
                        {% if user.isPilote() %}
                            <li class="nav-item"><a class="nav-link text-dark" href="/offres">Offres</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" href="/entreprises">Entreprises</a></li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/candidatures/gestion">
                                    <i class="bi bi-clipboard-check me-1"></i>Candidatures
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/campus/liste">
                                    <i class="bi bi-building-fill me-1"></i>Campus
                                </a>
                            </li>
                        {% endif %}

                        {# ── ADMIN ── #}
                        {% if user.isAdmin() %}
                            <li class="nav-item"><a class="nav-link text-dark" href="/offres">Offres</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" href="/entreprises">Entreprises</a></li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/candidatures/gestion">
                                    <i class="bi bi-clipboard-check me-1"></i>Candidatures
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/campus/liste">
                                    <i class="bi bi-building-fill me-1"></i>Campus
                                </a>
                            </li>
                        {% endif %}

                        {# ── PROFIL + DÉCONNEXION (tous les connectés) ── #}
                        <li class="nav-item"><a class="nav-link text-dark" href="/profile">
                            <i class="bi bi-person-circle me-1"></i>Profil
                        </a></li>
                        <li class="nav-item">
                            <a class="nav-link text-danger d-flex align-items-center gap-1" href="/logout">
                                <i class="bi bi-box-arrow-right"></i> Déconnexion
                            </a>
                        </li>

                    {% else %}
                        {# ── NON CONNECTÉ ── #}
                        <li class="nav-item"><a class="nav-link text-dark" href="/offres">Offres</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" href="/entreprises">Entreprises</a></li>
                        <li class="nav-item">
                            <a class="nav-link text-dark d-flex align-items-center gap-1" href="/Login">
                                <i class="bi bi-person-circle"></i> Connexion
                            </a>
                        </li>
                    {% endif %}

                </ul>
            </div>
        </nav>
    </header>

    {# ── BARRE DE RECHERCHE ── #}
    <div class="d-flex align-items-center border border-2 border-primary rounded-pill px-2 py-1 mx-auto my-2 w-50">
        <div class="dropdown me-1">
            <button class="btn btn-primary btn-sm rounded-pill dropdown-toggle fw-semibold px-3"
                    type="button" data-bs-toggle="dropdown">
                Offre
            </button>
            <ul class="dropdown-menu shadow-sm border-0 mt-1">
                <li><a class="dropdown-item" href="/offres">Offre</a></li>
                <li><a class="dropdown-item" href="/entreprises">Entreprise</a></li>
                {% if user and user.isEtudiant() %}
                    <li><a class="dropdown-item" href="/candidatures">Mes candidatures</a></li>
                {% endif %}
                {% if user and user.isAtLeastPilote() %}
                    <li><a class="dropdown-item" href="{{ url_for('liste_etudiants') }}">Les Étudiants</a></li>
                    <li><a class="dropdown-item" href="/candidatures/gestion">Candidatures</a></li>
                    <li><a class="dropdown-item" href="/campus/liste">Campus</a></li>
                {% endif %}
                {% if user and user.isAdmin() %}
                    <li><a class="dropdown-item" href="{{ url_for('liste_pilotes') }}">Les Pilotes</a></li>
                    <li><a class="dropdown-item" href="/compte">Créer un compte</a></li>
                {% endif %}
            </ul>
        </div>

        <input type="text"
               class="form-control border-0 shadow-none bg-transparent"
               placeholder="Rechercher...">

        <button class="btn btn-primary btn-sm rounded-pill px-3" type="submit">
            <i class="bi bi-search"></i>
        </button>
    </div>

    <title>{% block title %}{% endblock %} - My Webpage</title>

    <main id="content">{% block content %}{% endblock %}</main>

    <footer id="footer">
        {% block footer %}
        <div class="container-fluid bg-white py-3 border-top border-1 d-flex justify-content-center shadow">
            <a href="/mentions" class="text-black text-decoration-none small">
                <i class="bi bi-file-text text-black me-1"></i>Mentions légales
            </a>
        </div>
        {% endblock %}
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>