<!DOCTYPE html>
<html>
<head>
    {% block head %}
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Offres recommandées</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    {% endblock %}

    <style>
        body { font-family: 'Noto Sans', sans-serif; background: #f3f2f1; }

        .job-card {
            cursor: pointer;
            border-left: 3px solid transparent !important;
            transition: background 0.15s, border-color 0.15s;
        }
        .job-card:hover { background: #f9f8f7; }
        .job-card.active { background: #eef3fc !important; border-left-color: #2d6ef5 !important; }

        .badge-urgent { background: #fff3cd; color: #7a4a00; border: 1px solid #f5c518; }
        .badge-delay  { background: #e8f4ea; color: #1a6630; border: 1px solid #a3d9a5; }
        .badge-salary { background: #e6f7ed; color: #1a6630; border: 1px solid #7ecb97; }

        .tag-pill { font-size: .72rem; padding: 2px 10px; border-radius: 20px; border: 1px solid #d4d2d0; background: #fff; color: #1a1a1a; }

        .detail-panel { position: sticky; top: 16px; max-height: 90vh; overflow-y: auto; }

        .btn-postuler { background: #2d6ef5; font-weight: 700; font-size: .88rem; }
        .btn-postuler:hover { background: #1a5ae0; }

        .skill-chip { font-size: .75rem; padding: 4px 12px; border-radius: 20px; border: 1px solid #2d6ef5; color: #2d6ef5; background: #eef3fc; }
        .meta-chip  { font-size: .78rem; padding: 4px 14px; border-radius: 20px; border: 1px solid #d4d2d0; background: #f3f2f1; }

        .icon-btn { background: none; border: 1px solid #d4d2d0; border-radius: 4px; width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; font-size: .95rem; color: #595959; transition: background .1s; }
        .icon-btn:hover { background: #e4e2e0; }

        .apply-link { color: #2d6ef5; font-size: .75rem; font-weight: 600; text-decoration: none; }
    </style>
</head>

<body>

    {# ── NAVBAR ── #}
    <header>
        <nav class="navbar navbar-expand-lg bg-white border-bottom px-4">
            <a class="navbar-brand fw-bold" href="#">MonSite</a>

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarMain"
                    aria-controls="navbarMain"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="#"></a>
                    </li>
                </ul>
                <ul class="navbar-nav align-items-center">
                    <li class="nav-item"><a class="nav-link text-dark" href="#">Wishlist</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="#">Consultation</a></li>
                    <li class="nav-item"><a class="nav-link text-dark fw-semibold" aria-current="page" href="#">Profil</a></li>
                    <li class="nav-item">
                        <a class="nav-link text-dark px-2" href="#">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/>
                            </svg>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark d-flex align-items-center gap-1" href="#">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                            </svg>
                            Se connecter
                        </a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>

            <title>{% block title %}{% endblock %} - My Webpage</title>
    </head>
    <body>
        <main id="content">{% block content %}{% endblock %}</main>
        <footer id="footer">
            {% block footer %}
                &copy; Copyright 2011 by <a href="https://example.com/">you</a>.
            {% endblock %}
        </footer>
    </body>
</html>